# =============================================================================
# HASAN SHOP — Environment Configuration
# Copy to .env and fill in values. Never commit .env to version control.
# Production: use .env.production.example → .env.production
# =============================================================================

# Application
NODE_ENV=development
APP_NAME=HASAN SHOP
APP_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000
PORT=4000

# Database
DATABASE_URL=postgresql://hasan_shop:hasan_shop_dev@localhost:5433/hasan_shop
POSTGRES_USER=hasan_shop
POSTGRES_PASSWORD=hasan_shop_dev
POSTGRES_DB=hasan_shop

# Redis
REDIS_URL=redis://localhost:6379

# Meilisearch
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=hasan_shop_meili_dev_key

# Authentication
AUTH_SECRET=change-me-to-a-64-char-random-string-in-production-use-openssl-rand
AUTH_SESSION_EXPIRY_HOURS=168
AUTH_2FA_ISSUER=HASAN SHOP
SEED_ADMIN_PASSWORD=DevOnly@HasanShop2026!Secure
ADMIN_EMAIL=admin@hasan-shop.dz
ADMIN_PASSWORD=DevOnly@HasanShop2026!Secure

# Webhooks (required in production)
WEBHOOK_SECRET_DEFAULT=dev-webhook-secret-change-in-production
WEBHOOK_SECRET_PREVIOUS_DEFAULT=
WEBHOOK_SECRET_YALIDINE=
WEBHOOK_SECRET_PREVIOUS_YALIDINE=

# Object Storage (S3-compatible / Cloudflare R2)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=hasan_shop_minio
S3_SECRET_KEY=hasan_shop_minio_secret
S3_BUCKET=hasan-shop
S3_REGION=auto
S3_PUBLIC_URL=http://localhost:9000/hasan-shop

# Malware scanning (optional in dev; required in production)
CLAMAV_HOST=
CLAMAV_PORT=3310
CLAMAV_REQUIRED=false

# Yalidine Shipping (credentials also stored in carrier_configs table)
YALIDINE_API_ID=
YALIDINE_API_TOKEN=
YALIDINE_API_URL=https://api.yalidine.app/v1

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=orders@hasan-shop.dz

# WhatsApp
WHATSAPP_WEBHOOK_URL=
FEATURE_WHATSAPP_NOTIFICATIONS=false

# SMS (configure when provider is selected)
SMS_API_KEY=
SMS_SENDER=HASANSHOP

# Payment Gateway (feature-flagged)
PAYMENT_GATEWAY_ENABLED=false
PAYMENT_GATEWAY_PROVIDER=
PAYMENT_GATEWAY_API_KEY=
PAYMENT_GATEWAY_SECRET=

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Monitoring
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Backup
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_INTERVAL_SEC=86400

# Feature Flags
FEATURE_INTERNATIONAL_SUPPLIERS=false
FEATURE_ONLINE_PAYMENTS=false

# E2E / CI
STOREFRONT_URL=http://localhost:3000
CI=false
