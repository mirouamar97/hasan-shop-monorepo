# =============================================================================
# HASAN SHOP — Production Environment (Docker Compose)
# Copy to .env.production and replace ALL secrets before deploy.
# Generate secrets: openssl rand -base64 48
# =============================================================================

NODE_ENV=production

# Public URLs (used for CORS, metadata, and client builds)
APP_URL=https://shop.example.dz
ADMIN_URL=https://admin.example.dz
API_URL=https://api.example.dz
NEXT_PUBLIC_API_URL=https://api.example.dz
NEXT_PUBLIC_APP_URL=https://shop.example.dz

# PostgreSQL
POSTGRES_USER=hasan_shop
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
POSTGRES_DB=hasan_shop
DATABASE_URL=postgresql://hasan_shop:REPLACE_WITH_STRONG_PASSWORD@postgres:5432/hasan_shop

# Redis
REDIS_URL=redis://redis:6379

# Meilisearch
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_API_KEY=REPLACE_WITH_MEILI_MASTER_KEY

# Authentication (32+ characters)
AUTH_SECRET=REPLACE_WITH_OPENSSL_RAND_BASE64_48
AUTH_SESSION_EXPIRY_HOURS=168

# Webhook secrets (rotate using WEBHOOK_SECRET_PREVIOUS_* during rotation window)
WEBHOOK_SECRET_DEFAULT=REPLACE_WITH_WEBHOOK_SECRET
WEBHOOK_SECRET_PREVIOUS_DEFAULT=
WEBHOOK_SECRET_YALIDINE=
WEBHOOK_SECRET_PREVIOUS_YALIDINE=

# Object Storage (MinIO in Compose; use R2/S3 in cloud)
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=REPLACE_MINIO_ACCESS_KEY
S3_SECRET_KEY=REPLACE_MINIO_SECRET_KEY
S3_BUCKET=hasan-shop
S3_REGION=auto
S3_PUBLIC_URL=https://cdn.example.dz/hasan-shop

# Malware scanning (ClamAV container)
CLAMAV_HOST=clamav
CLAMAV_PORT=3310
CLAMAV_REQUIRED=true

# Email (Resend)
RESEND_API_KEY=re_REPLACE_WITH_RESEND_KEY
RESEND_FROM_EMAIL=orders@hasan-shop.dz

# WhatsApp notifications (optional)
FEATURE_WHATSAPP_NOTIFICATIONS=false
WHATSAPP_WEBHOOK_URL=

# Backup
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_INTERVAL_SEC=86400

# HTTP ports (nginx)
HTTP_PORT=80
HTTPS_PORT=443

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Feature flags
FEATURE_ONLINE_PAYMENTS=false
FEATURE_INTERNATIONAL_SUPPLIERS=false

# Do not seed production — create admin via secure process
SEED_ON_DEPLOY=false
