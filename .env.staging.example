# =============================================================================
# HASAN SHOP — Staging Environment (RC1 notification verification)
# Copy to .env.staging and fill credentials before LB-3 sign-off.
# =============================================================================

NODE_ENV=staging

APP_URL=https://staging.shop.example.dz
ADMIN_URL=https://staging.admin.example.dz
API_URL=https://staging.api.example.dz
NEXT_PUBLIC_API_URL=https://staging.api.example.dz
NEXT_PUBLIC_APP_URL=https://staging.shop.example.dz

DATABASE_URL=postgresql://hasan_shop:REPLACE@localhost:5433/hasan_shop
REDIS_URL=redis://localhost:6379
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=staging-meili-key

AUTH_SECRET=REPLACE_WITH_48_CHAR_RANDOM_STRING
WEBHOOK_SECRET_DEFAULT=REPLACE_WITH_WEBHOOK_SECRET

S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=hasan-shop
S3_PUBLIC_URL=http://localhost:9000/hasan-shop

CLAMAV_HOST=localhost
CLAMAV_PORT=3310

# LB-3 — Required for notification verification
RESEND_API_KEY=re_REPLACE_WITH_RESEND_API_KEY
RESEND_FROM_EMAIL=orders@staging.hasan-shop.dz

FEATURE_WHATSAPP_NOTIFICATIONS=true
WHATSAPP_WEBHOOK_URL=https://REPLACE_WITH_WHATSAPP_PROVIDER_WEBHOOK

# Verification commands (after stack is up):
# curl -s http://localhost:4000/api/v1/health | jq .
# Place a test order and confirm email + WhatsApp delivery in notification logs
