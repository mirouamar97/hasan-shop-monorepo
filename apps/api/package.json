{
  "name": "@hasan-shop/api",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --exclude 'src/test/integration/**'",
    "test:ci": "vitest run --coverage --exclude 'src/test/integration/**'",
    "test:integration": "vitest run src/test/integration --reporter=verbose",
    "test:coverage": "vitest run --coverage",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@hasan-shop/carrier-adapters": "workspace:*",
    "@hasan-shop/database": "workspace:*",
    "@hasan-shop/logger": "workspace:*",
    "@hasan-shop/shared": "workspace:*",
    "@nestjs/common": "^11.1.3",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.3",
    "@nestjs/platform-express": "^11.1.3",
    "@nestjs/throttler": "^6.4.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "cookie-parser": "^1.4.7",
    "helmet": "^8.1.0",
    "ioredis": "^5.6.1",
    "@aws-sdk/client-s3": "^3.826.0",
    "@aws-sdk/s3-request-presigner": "^3.826.0",
    "otplib": "^12.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@hasan-shop/config-eslint": "workspace:*",
    "@hasan-shop/config-typescript": "workspace:*",
    "@nestjs/cli": "^11.0.5",
    "@nestjs/schematics": "^11.0.5",
    "@nestjs/testing": "^11.1.3",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.9",
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.29",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^3.2.1",
    "supertest": "^7.1.1",
    "dotenv": "^16.5.0",
    "eslint": "^9.28.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.1"
  }
}
